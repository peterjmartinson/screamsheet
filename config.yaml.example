# Screamsheet user preferences — EXAMPLE FILE
# Copy this to config.yaml and fill in your own teams.
# Teams are listed in priority order. On days when the first team didn't play,
# the next team in the list is checked, and so on.
#
# NHL team IDs: https://api-web.nhle.com/v1/standings/now  (look for "id" in each team record)
# MLB team IDs: https://statsapi.mlb.com/api/v1/teams?sportId=1
# NBA team IDs: use nba_api  (e.g. nba_api.stats.static.teams.get_teams())
# NFL team IDs: confirm via your NFL data provider

# Branding footer — printed at the bottom of every screamsheet page.
branding: "DISTRACTEDFORTUNE.COM"
nhl:
  favorite_teams:
    - id: 4
      name: "Philadelphia Flyers"
    - id: 7
      name: "Buffalo Sabres"
    - id: 12
      name: "Carolina Hurricanes"

mlb:
  favorite_teams:
    - id: 143
      name: "Philadelphia Phillies"
    - id: 135
      name: "San Diego Padres"
    - id: 147
      name: "New York Yankees"
  # Short names used by the news and trade-rumors sheets to filter articles.
  news_names:
    - "Phillies"
    - "Padres"
    - "Yankees"

nba:
  favorite_teams:
    - id: 1610612755
      name: "Philadelphia 76ers"
    - id: 1610612752
      name: "New York Knicks"
    - id: 1610612749
      name: "Milwaukee Bucks"

nfl:
  favorite_teams:
    - id: 4
      name: "Philadelphia Eagles"

# Weather locations for each screamsheet type.
# Uses the National Weather Service API (US locations only).
# Find lat/lon for your city at https://www.latlong.net/
weather:
  presidential:
    lat: 38.8951
    lon: -77.0364
    location_name: "Washington, DC"
  mlb_news:
    lat: 40.02
    lon: -75.34
    location_name: "Bryn Mawr, PA"

# Sky Tonight location.
# Find lat/lon for your city at https://www.latlong.net/
sky:
  lat: 40.02
  lon: -75.34
  location_name: "Bryn Mawr, PA"
  people:
    - name: "__PERSON1_NAME__"
      sun_sign: "__PERSON1_SUN_SIGN__"
      moon_sign: "__PERSON1_MOON_SIGN__"
      ascendant: "__PERSON1_ASCENDANT__"
    - name: "__PERSON2_NAME__"
      sun_sign: "__PERSON2_SUN_SIGN__"
      moon_sign: "__PERSON2_MOON_SIGN__"
      ascendant: "__PERSON2_ASCENDANT__"

# Database path for the SQLite team/player cache.
# The SCREAMSHEET_DB environment variable takes precedence if set.
# In CI, __DB_PATH__ is substituted by the deploy workflow using the
# DB_PATH GitHub repository variable.
database:
  path: __DB_PATH__

# Output directory: generated PDFs are copied here after generation.
# Override per-run with: uv run screamsheet --output-dir /path/to/dir
# In CI, __PRINT_DIR__ is substituted by the deploy workflow using the
# PRINT_DIR GitHub repository variable.
output:
  directory: __PRINT_DIR__
